<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Portal Clientes — Amorim</title>
  <link rel="stylesheet" href="/static/css/portal.css?v=<%= Date.now() %>" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" crossorigin="anonymous" />
</head>
<body class="portal-body">

  <!-- Header -->
  <header class="portal-header">
    <div class="portal-header-brand">
      <img src="/static/img/logo-amorim.png" alt="Amorim" class="portal-header-logo"
           onerror="this.style.display='none';" />
      <span class="portal-header-logo-text">Portal Clientes</span>
    </div>
    <div class="portal-header-right">
      <span class="portal-header-user">
        <i class="fas fa-building"></i>
        <%= user.cliente_nombre || user.email %>
      </span>
      <button type="button" class="portal-logout-btn" id="btn-portal-logout">
        <i class="fas fa-sign-out-alt"></i> Salir
      </button>
    </div>
  </header>

  <!-- Tabs de navegación -->
  <nav class="portal-tabs" id="portal-tabs">
    <button class="portal-tab-btn active" data-tab="reparaciones">
      <i class="fas fa-tools"></i> Equipos en Reparación
    </button>
    <button class="portal-tab-btn" data-tab="historial">
      <i class="fas fa-history"></i> Historial
    </button>
    <button class="portal-tab-btn" data-tab="garantias">
      <i class="fas fa-shield-alt"></i> Garantías
    </button>
    <button class="portal-tab-btn" data-tab="presupuestos">
      <i class="fas fa-file-invoice-dollar"></i> Presupuestos
    </button>
  </nav>

  <!-- Contenido principal -->
  <main class="portal-main">
    <div id="portal-content">
      <div class="portal-spinner">Cargando</div>
    </div>
  </main>

  <script src="/static/scripts/portal.js?v=<%= Date.now() %>"></script>
</body>
</html>
